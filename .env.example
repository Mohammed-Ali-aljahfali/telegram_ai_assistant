# ─── Telegram ──────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
API_ID=your_api_id_here
API_HASH=your_api_hash_here
DEVELOPER_ID=your_telegram_id_here
ENCRYPTION_KEY=generate_with_fernet_generate_key

# ─── التخزين الدائم ────────────────────────────────────────────────────────
# على Railway: اضبط على /data (مسار Volume)
# محلياً: اتركه فارغاً أو اضبط على ./data
DATA_DIR=/data

# ─── السجلات ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── الذكاء الاصطناعي ─────────────────────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=
LOCAL_AI_URL=http://localhost:11434
