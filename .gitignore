#         وليس في مجلد الكود، لذا لا توجد مشكلة في استبعادها من Git.
data/database.db
data/backups/
data/sessions/
data/logs/
data/

# ─── السجلات المحلية ───────────────────────────────────────────────────────
logs/
*.log

