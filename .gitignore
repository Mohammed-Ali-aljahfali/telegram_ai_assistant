# ─── متغيرات البيئة ────────────────────────────────────────────────────────
.env

# ─── Python Cache ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# ─── بيانات التطوير المحلي (لا تُرفع على Git) ────────────────────────────
